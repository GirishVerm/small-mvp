# Copy this to .env for local development.
# In production (Render), set these in the Render dashboard under Environment.

# --- Linear ---
LINEAR_API_KEY=lin_api_...
LINEAR_SPRINT_ISSUE_ID=          # optional: Linear issue ID to post sprint summaries to

# --- GitHub ---
GITHUB_WEBHOOK_SECRET=           # must match the secret you set in GitHub → Settings → Webhooks

# --- Linear Webhooks ---
LINEAR_WEBHOOK_SECRET=           # must match the secret you set in Linear → Settings → API → Webhooks

# --- Local only (Render sets these automatically via render.yaml) ---
PORT=3000
ANALYTICS_DB_PATH=               # leave blank locally (defaults to ./data/analytics.db)
